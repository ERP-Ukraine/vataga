// If you want to run as a non-root user in the container, see .devcontainer/docker-compose.yml.
{
	"name": "Odoo SaaS",
	// Update the 'dockerComposeFile' list if you have more compose files or use different names.
	// The .devcontainer/docker-compose.yml file contains any overrides you need/want to make.
	"dockerComposeFile": [
		"../docker-compose.yml",
		"docker-compose.yml"
	],
	// The 'service' property is the name of the service for the container that VS Code should
	// use. Update this value and .devcontainer/docker-compose.yml to the real service name.
	"service": "saas-odoo",
	// The optional 'workspaceFolder' property is the path VS Code should open by default when
	// connected. This is typically a file mount in .devcontainer/docker-compose.yml
	"workspaceFolder": "/mnt/extra-addons",
	// Use 'settings' to set *default* container specific settings.json values on container create.
	// You can edit these settings after create using File > Preferences > Settings > Remote.
	"customizations": {
		"vscode": {
			"settings": {
				// This will ignore your local shell user setting for Linux since shells like zsh are typically
				// not in base container images. You can also update this to an specific shell to ensure VS Code
				// uses the right one for terminals and tasks. For example, /bin/bash (or /bin/ash for Alpine).
			},
			"extensions": [
				"charliermarsh.ruff",
				"atlassian.atlascode",
				"davidanson.vscode-markdownlint",
				"dbaeumer.vscode-eslint",
				"dotjoshjohnson.xml",
				"eamodio.gitlens",
				"kevinrose.vsc-python-indent",
				"lextudio.restructuredtext",
				"mechatroner.rainbow-csv",
				"michelemelluso.code-beautifier",
				"mrmlnc.vscode-scss",
				"mrorz.language-gettext",
				"ms-azuretools.vscode-docker",
				"ms-python.python",
				"ms-vscode.atom-keybindings",
				"ms-vscode.go",
				"mtxr.sqltools",
				"njpwerner.autodocstring",
				"redhat.vscode-yaml",
				"redhat.vscode-xml",
				"sibiraj-s.vscode-scss-formatter",
				"streetsidesoftware.code-spell-checker",
				"streetsidesoftware.code-spell-checker-ukrainian",
				"tyriar.sort-lines",
				"ms-python.vscode-pylance",
				"trond-snekvik.simple-rst"
			]
		}
	},
	// Uncomment the next line to have VS Code connect as an existing non-root user in the container. See
	// https://aka.ms/vscode-remote/containers/non-root for details on adding a non-root user if none exist.
	"remoteUser": "vscode",
	"containerUser": "odoo",
	// Uncomment the next line if you want start specific services in your Docker Compose config.
	// "runServices": ["db-custom11", "redis"],
	// Uncomment the next line if you want to keep your containers running after VS Code shuts down.
	"shutdownAction": "stopCompose",
	// Uncomment the next line to run commands after the container is created - for example installing git.
	// "postCreateCommand": "apt-get update && apt-get install -y git",
	// Add the IDs of extensions you want installed when the container is created in the array below.
	"remoteEnv": {
		"PGHOST": "pg13odoo",
		"PGUSER": "odoo",
		"PGPASSWORD": "odoo"
	}
}
