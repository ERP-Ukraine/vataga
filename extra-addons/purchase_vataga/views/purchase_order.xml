<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="purchase_order_form_purchase" model="ir.ui.view">
        <field name="name">purchase.order.form.purchase</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']/.." position="inside">
                <field name="project_account_id" readonly="state in ('done', 'cancel')"
                groups="analytic.group_analytic_accounting"
                options="{'no_create': True, 'no_open': True}" />
                <field name="budget_account_id" readonly="state in ('done', 'cancel')"
                groups="analytic.group_analytic_accounting"
                options="{'no_create': True, 'no_open': True}" />
                <field name="cash_flow_item_account_id" readonly="state in ('done', 'cancel')"
                groups="analytic.group_analytic_accounting"
                options="{'no_create': True, 'no_open': True}" />
                <field name="seller_contract_id" readonly="state in ('done', 'cancel')"
                groups="analytic.group_analytic_accounting"
                options="{'no_create': True, 'no_open': True}" />
            </xpath>
            <xpath expr="//field[@name='order_line']//field[@name='product_id']" position="after">
                <field name="supplier_product_name_for_import" readonly="1" groups="base.group_no_one" optional="hide"/>
                <field name="supplier_product_code_for_import" readonly="1" groups="base.group_no_one" optional="hide"/>
            </xpath>
        </field>
    </record>

</odoo>
