<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_move_form_account" model="ir.ui.view">
        <field name="name">view.move.form.account</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form" />
        <field name="arch" type="xml">
            <xpath expr="//group[@id='header_left_group']" position="inside">
                <field name="project_account_id" readonly="state != 'draft'"
                    groups="analytic.group_analytic_accounting"
                    invisible="move_type != 'in_invoice'"
                    options="{'no_create': True, 'no_open': True}" />
                <field name="budget_account_id" readonly="state != 'draft'"
                    groups="analytic.group_analytic_accounting"
                    invisible="move_type != 'in_invoice'"
                    options="{'no_create': True, 'no_open': True}" />
                <field name="cash_flow_item_account_id" readonly="state != 'draft'"
                    groups="analytic.group_analytic_accounting"
                    invisible="move_type != 'in_invoice'"
                    options="{'no_create': True, 'no_open': True}" />
                <field name="seller_contract_id" readonly="state != 'draft'"
                    groups="analytic.group_analytic_accounting"
                    invisible="move_type != 'in_invoice'"
                    options="{'no_create': True, 'no_open': True}" />
            </xpath>
        </field>
    </record>

</odoo>
